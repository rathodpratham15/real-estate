{
  "name": "real-estate-website",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node ace serve --hmr",
    "build": "node ace build --ignore-ts-errors",
    "start": "node bin/server.js",
    "migrate": "node ace migration:run",
    "migrate:rollback": "node ace migration:rollback",
    "migrate:fresh": "node ace migration:fresh",
    "test": "node ace test",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "web:dev": "pnpm --filter vercel-web dev",
    "web:build": "pnpm --filter vercel-web build"
  },
  "imports": {
    "#controllers/*": "./app/controllers/*.js",
    "#models/*": "./app/models/*.js",
    "#exceptions/*": "./app/exceptions/*.js",
    "#middleware/*": "./app/middleware/*.js",
    "#services/*": "./app/services/*.js",
    "#start/*": "./start/*.js",
    "#config/*": "./config/*.js",
    "#database/*": "./database/*.js"
  },
  "dependencies": {
    "@adonisjs/auth": "^9.5.1",
    "@adonisjs/core": "^6.17.1",
    "@adonisjs/cors": "^2.2.1",
    "@adonisjs/hash": "^9.1.1",
    "@adonisjs/inertia": "^3.1.1",
    "@adonisjs/lucid": "^21.6.0",
    "@adonisjs/mail": "^9.2.2",
    "@adonisjs/session": "^7.5.0",
    "@adonisjs/shield": "^8.1.1",
    "@adonisjs/static": "^1.1.1",
    "@adonisjs/vite": "^4.0.0",
    "@inertiajs/react": "2.2.19",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-toast": "^1.2.15",
    "@vinejs/vine": "^4.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.29.0",
    "lucide-react": "^0.511.0",
    "luxon": "^3.7.2",
    "pg": "^8.13.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "reflect-metadata": "^0.2.2",
    "sonner": "^2.0.3",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@adonisjs/assembler": "^7.8.2",
    "@adonisjs/eslint-config": "^2.1.2",
    "@adonisjs/prettier-config": "^1.4.5",
    "@adonisjs/tsconfig": "^1.4.1",
    "@swc/core": "^1.15.10",
    "@tailwindcss/vite": "^4.1.7",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.4",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.5.2",
    "eslint": "^9.39.1",
    "hot-hook": "^0.4.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.7.1",
    "tailwindcss": "^4.1.7",
    "ts-node": "^10.9.2",
    "typescript": "~5.7.2",
    "vite": "6.3.5"
  }
}
